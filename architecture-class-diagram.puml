' ===========================================
' DESIGN PATTERNS - STRATEGY (Evaluation)
' ===========================================
package "Patterns::Strategy::Evaluation" <<Pattern>> {
    interface EvaluationStrategy <<Pattern>> {
        +evaluate(exam: IExam, responses: any[], questions: any[]): Promise<EvaluationResult>
    }

    class QCMEvaluationStrategy <<Pattern>> {
        +evaluate(): Promise<EvaluationResult>
    }

    class TrueFalseEvaluationStrategy <<Pattern>> {
        +evaluate(): Promise<EvaluationResult>
    }

    class AdaptiveEvaluationStrategy <<Pattern>> {
        +evaluate(): Promise<EvaluationResult>
        -getDifficultyMultiplier(difficulty: string): number
    }

    class ExamSimulationStrategy <<Pattern>> {
        +evaluate(): Promise<EvaluationResult>
    }

    class OpenQuestionEvaluationStrategy <<Pattern>> {
        +evaluate(): Promise<EvaluationResult>
        -gradeByKeywords(): number
        -gradeBySemantic(): number
    }

    class ConceptSelfEvaluationStrategy <<Pattern>> {
        +evaluate(input: ConceptEvaluationInput): ConceptEvaluationResult
        +save(input: ConceptEvaluationInput): Promise<any>
    }

    EvaluationStrategy <|.. QCMEvaluationStrategy
    EvaluationStrategy <|.. TrueFalseEvaluationStrategy
    EvaluationStrategy <|.. AdaptiveEvaluationStrategy
    EvaluationStrategy <|.. ExamSimulationStrategy
    EvaluationStrategy <|.. OpenQuestionEvaluationStrategy
}

' ===========================================
' DESIGN PATTERNS - STRATEGY (Authentication)
' ===========================================
package "Patterns::Strategy::Authentication" <<Pattern>> {
    interface IAuthStrategy <<Pattern>> {
        +id: string
        +name: string
        +icon: string
        +getProvider(): Provider
        +handleSignIn(profile: any, account: any): Promise<boolean>
        +transformSession(session: Session, token: any): Promise<Session>
        +isEnabled(): boolean
    }

    abstract class BaseAuthStrategy <<Pattern>> {
        +{abstract} id: string
        +{abstract} name: string
        +icon: string
        +{abstract} getProvider(): Provider
        +handleSignIn(profile: any, account: any): Promise<boolean>
        +transformSession(session: Session, token: any): Promise<Session>
        +{abstract} isEnabled(): boolean
        #checkEnvVars(...vars: string[]): boolean
    }

    class CredentialsAuthStrategy <<Pattern>> {
        +id: "credentials"
        +name: "Email & Password"
        +getProvider(): Provider
        +isEnabled(): boolean
    }

    class GoogleAuthStrategy <<Pattern>> {
        +id: "google"
        +name: "Google"
        +getProvider(): Provider
        +handleSignIn(profile: any, account: any): Promise<boolean>
        +isEnabled(): boolean
    }

    class GitHubAuthStrategy <<Pattern>> {
        +id: "github"
        +name: "GitHub"
        +getProvider(): Provider
        +handleSignIn(profile: any, account: any): Promise<boolean>
        +isEnabled(): boolean
    }

    class AuthStrategyManager <<Pattern>> {
        -{static} instance: AuthStrategyManager
        -strategies: Map<string, IAuthStrategy>
        +{static} getInstance(): AuthStrategyManager
        -registerStrategies(): void
        -registerStrategy(strategy: IAuthStrategy): void
        +getStrategy(id: string): IAuthStrategy
        +getAllStrategies(): IAuthStrategy[]
        +getEnabledStrategies(): IAuthStrategy[]
        +getEnabledProviders(): Provider[]
        +handleSignIn(strategyId: string, profile: any, account: any): Promise<boolean>
        +isProviderEnabled(id: string): boolean
    }

    IAuthStrategy <|.. BaseAuthStrategy
    BaseAuthStrategy <|-- CredentialsAuthStrategy
    BaseAuthStrategy <|-- GoogleAuthStrategy
    BaseAuthStrategy <|-- GitHubAuthStrategy
    AuthStrategyManager o--> IAuthStrategy : manages
}

' ===========================================
' DESIGN PATTERNS - DECORATOR
' ===========================================
package "Patterns::Decorator" <<Pattern>> {
    interface ExamDecorator <<Pattern>> {
        +decorate(exam: IExam): IExam
        +enhanceResult(result: EvaluationResult, exam: IExam): EvaluationResult
    }

    abstract class BaseExamDecorator <<Pattern>> {
        #decoratedExam: IExam
        +{abstract} decorate(exam: IExam): IExam
        +enhanceResult(): EvaluationResult
    }

    class TimeBonusDecorator <<Pattern>> {
        +decorate(): IExam
        +enhanceResult(): EvaluationResult
    }

    class StreakBonusDecorator <<Pattern>> {
        +decorate(): IExam
        +enhanceResult(): EvaluationResult
    }

    class TimePenaltyDecorator <<Pattern>> {
        +decorate(): IExam
        +enhanceResult(): EvaluationResult
    }

    class BadgeDecorator <<Pattern>> {
        +decorate(): IExam
        +enhanceResult(): EvaluationResult
    }

    class DetailedStatsDecorator <<Pattern>> {
        +decorate(): IExam
        +enhanceResult(): EvaluationResult
    }

    ExamDecorator <|.. BaseExamDecorator
    BaseExamDecorator <|-- TimeBonusDecorator
    BaseExamDecorator <|-- StreakBonusDecorator
    BaseExamDecorator <|-- TimePenaltyDecorator
    BaseExamDecorator <|-- BadgeDecorator
    BaseExamDecorator <|-- DetailedStatsDecorator
}

' ===========================================
' DESIGN PATTERNS - BUILDER
' ===========================================
package "Patterns::Builder" <<Pattern>> {
    class SyllabusBuilder <<Pattern>> {
        -syllabus: Partial<ISyllabus>
        -structure: SyllabusStructure
        +setBasicInfo(): SyllabusBuilder
        +setContext(): SyllabusBuilder
        +setClasses(): SyllabusBuilder
        +addObjective(): SyllabusBuilder
        +addChapter(): string
        +addTopic(): string
        +addConcept(): SyllabusBuilder
        +addResource(): SyllabusBuilder
        +build(): Partial<ISyllabus>
        +{static} fromExisting(): SyllabusBuilder
    }
}

' ===========================================
' DESIGN PATTERNS - COMPOSITE
' ===========================================
package "Patterns::Composite" <<Pattern>> {
    interface EducationalComponent <<Pattern>> {
        +_id: ObjectId
        +name: string
        +code: string
        +getChildren(): Promise<EducationalComponent[]>
        +getParent(): Promise<EducationalComponent>
        +getPath(): Promise<string[]>
        +getDepth(): Promise<number>
        +isLeaf(): Promise<boolean>
        +getAncestors(): Promise<EducationalComponent[]>
        +getDescendants(): Promise<EducationalComponent[]>
    }

    abstract class BaseEducationalComponent <<Pattern>> {
        +_id: ObjectId
        +name: string
        +code: string
        +{abstract} getChildren(): Promise<EducationalComponent[]>
        +{abstract} getParent(): Promise<EducationalComponent>
        +getPath(): Promise<string[]>
        +getAncestors(): Promise<EducationalComponent[]>
    }

    class EducationLevelComponent <<Pattern>> {
        +subSystem: string
        +cycle: string
        +getChildren(): Promise<EducationalComponent[]>
        +getParent(): Promise<EducationalComponent>
    }

    class FieldComponent <<Pattern>> {
        +parentField: ObjectId
        +childFields: ObjectId[]
        +getChildren(): Promise<EducationalComponent[]>
        +getParent(): Promise<EducationalComponent>
    }

    class SubjectComponent <<Pattern>> {
        +parentSubject: ObjectId
        +getChildren(): Promise<EducationalComponent[]>
        +getParent(): Promise<EducationalComponent>
    }

    class LearningUnitComponent <<Pattern>> {
        +parentUnit: ObjectId
        +subject: ObjectId
        +getChildren(): Promise<EducationalComponent[]>
        +getParent(): Promise<EducationalComponent>
    }

    EducationalComponent <|.. BaseEducationalComponent
    BaseEducationalComponent <|-- EducationLevelComponent
    BaseEducationalComponent <|-- FieldComponent
    BaseEducationalComponent <|-- SubjectComponent
    BaseEducationalComponent <|-- LearningUnitComponent
    EducationalComponent o--> EducationalComponent : children
}

' ===========================================
' DESIGN PATTERNS - OBSERVER
' ===========================================
package "Patterns::Observer" <<Observer>> {
    interface IObserver <<Observer>> {
        +update(event: Event): Promise<void>
        +getName(): string
        +getInterestedEvents(): string[]
    }

    class EventPublisher <<Observer>> {
        -{static} instance: EventPublisher
        -observers: Map<string, IObserver[]>
        -eventHistory: Event[]
        +{static} getInstance(): EventPublisher
        +subscribe(observer: IObserver): void
        +unsubscribe(observer: IObserver): void
        +publish(event: Event): Promise<void>
        -notifyObserver(): Promise<void>
        +getHistory(): Event[]
    }

    class EmailNotificationObserver <<Observer>> {
        +update(event: Event): Promise<void>
        +getName(): string
        +getInterestedEvents(): string[]
        -sendExamCompletedEmail(): Promise<void>
        -sendAttemptGradedEmail(): Promise<void>
        -sendBadgeEarnedEmail(): Promise<void>
    }

    class XPUpdateObserver <<Observer>> {
        +update(event: Event): Promise<void>
        +getName(): string
        +getInterestedEvents(): string[]
    }

    class NotificationObserver <<Observer>> {
        +update(event: Event): Promise<void>
        +getName(): string
        +getInterestedEvents(): string[]
    }

    class StatsUpdateObserver <<Observer>> {
        +update(event: Event): Promise<void>
        +getName(): string
        +getInterestedEvents(): string[]
    }

    class BadgeAwardObserver <<Observer>> {
        +update(event: Event): Promise<void>
        +getName(): string
        +getInterestedEvents(): string[]
    }

    IObserver <|.. EmailNotificationObserver
    IObserver <|.. XPUpdateObserver
    IObserver <|.. NotificationObserver
    IObserver <|.. StatsUpdateObserver
    IObserver <|.. BadgeAwardObserver
    EventPublisher --> IObserver : notifies
}

' ===========================================
' EVENTS
' ===========================================
package "Events" <<Event>> {
    enum EventType <<Event>> {
        EXAM_CREATED
        EXAM_COMPLETED
        ATTEMPT_STARTED
        BADGE_EARNED
        LEVEL_UP
        XP_GAINED
    }

    interface Event <<Event>> {
        +type: EventType
        +timestamp: Date
        +userId: ObjectId
        +data: Record<string, any>
    }

    class ExamCompletedEvent <<Event>> {
        +type: EventType.EXAM_COMPLETED
        +data: {examId, score, passed, ...}
    }

    class BadgeEarnedEvent <<Event>> {
        +type: EventType.BADGE_EARNED
        +data: {badgeId, badgeName, ...}
    }

    class AttemptGradedEvent <<Event>> {
        +type: EventType.ATTEMPT_GRADED
        +data: {attemptId, score, ...}
    }

    Event <|.. ExamCompletedEvent
    Event <|.. BadgeEarnedEvent
    Event <|.. AttemptGradedEvent
    Event --> EventType
}

' ===========================================
' FACTORIES
' ===========================================
package "Factories" <<Factory>> {
    class ProfileFactory <<Factory>> {
        +{static} createUser(userData: CreateUserDTO): Promise<{user, profile}>
        -{static} isPedagogicalRole(role: UserRole): boolean
    }

    class ProfileFactoryV2 <<Factory>> {
        +{static} createProfile(user: IUser): Promise<ILearnerProfile | IPedagogicalProfile>
        -{static} createLearnerProfile(user: IUser): Promise<ILearnerProfile>
        -{static} createPedagogicalProfile(user: IUser): Promise<IPedagogicalProfile>
    }

    class EvaluationStrategyFactory <<Factory>> {
        +{static} getStrategy(type: EvaluationType): EvaluationStrategy
        +{static} getConceptSelfEvaluationStrategy(): ConceptSelfEvaluationStrategy
        +{static} evaluateExam(): Promise<EvaluationResult>
    }

    class ExamDecoratorFactory <<Factory>> {
        +{static} applyDecorators(result: EvaluationResult, exam: IExam, options): EvaluationResult
    }

    class EducationalComponentFactory <<Factory>> {
        +{static} create(type: string, data: any): EducationalComponent
        +{static} createFromId(type: string, id: ObjectId): Promise<EducationalComponent>
    }

    ProfileFactory ..> User : creates
    ProfileFactory ..> LearnerProfile : creates
    ProfileFactory ..> PedagogicalProfile : creates
    ProfileFactoryV2 ..> LearnerProfile : creates/retrieves
    ProfileFactoryV2 ..> PedagogicalProfile : creates/retrieves
    EvaluationStrategyFactory ..> EvaluationStrategy : creates
    ExamDecoratorFactory ..> ExamDecorator : uses
    EducationalComponentFactory ..> EducationalComponent : creates
}

