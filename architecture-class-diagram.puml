@startuml Quizlock API - Architecture Complète

title Quizlock API - Diagramme de Classe Complet\nPatterns: Strategy, Decorator, Observer, Builder, Composite, Factory

!define PATTERN_COLOR #E8F5E9
!define MODEL_COLOR #E3F2FD
!define FACTORY_COLOR #FFF9C4
!define OBSERVER_COLOR #FCE4EC
!define EVENT_COLOR #F3E5F5

skinparam class {
    BackgroundColor<<Pattern>> PATTERN_COLOR
    BackgroundColor<<Model>> MODEL_COLOR
    BackgroundColor<<Factory>> FACTORY_COLOR
    BackgroundColor<<Observer>> OBSERVER_COLOR
    BackgroundColor<<Event>> EVENT_COLOR
    BorderColor #424242
    ArrowColor #616161
