          ]
        },
        {
          "name": "ERR — Supprimer sans être owner",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Cookie", "value": "next-auth.session-token={{sessionToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/syllabus/{{syllabusId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "syllabus", "{{syllabusId}}"]
            },
            "description": "Utiliser un token d'un autre enseignant pour tester le 403."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 403 si pas owner, 200 si owner",
                  "pm.test('Status 403 ou 200', () => {",
                  "    pm.expect([200, 403]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "ERR — Sync concepts sans syllabusId",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Cookie", "value": "next-auth.session-token={{sessionToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"concepts\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/concepts/sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "concepts", "sync"]
            },
            "description": "ATTENTION: la réponse d'erreur est { error: '...' } et non { success: false, message: '...' }."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('error key présente (pas message)', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('error');",
                  "    pm.expect(json).to.not.have.property('message');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "ERR — Auto-éval sans fields requis",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Cookie", "value": "next-auth.session-token={{sessionToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conceptId\": \"{{conceptId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/syllabus/concepts/evaluate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "syllabus", "concepts", "evaluate"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Missing required fields', () => {",
                  "    pm.expect(pm.response.json().message).to.include('Missing required fields');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "ERR — Non authentifié",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/syllabus",
              "host": ["{{baseUrl}}"],
              "path": ["api", "syllabus"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Unauthorized', () => {",
                  "    pm.expect(pm.response.json().message).to.include('Unauthorized');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
