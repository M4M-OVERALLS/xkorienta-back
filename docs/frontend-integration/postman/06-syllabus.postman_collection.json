            "method": "POST",
            "header": [
              { "key": "Cookie", "value": "next-auth.session-token={{sessionToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Syllabus sans matière\"\n}"
