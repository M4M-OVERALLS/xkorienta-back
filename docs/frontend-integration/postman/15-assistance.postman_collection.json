{
  "info": {
    "_postman_id": "15-assistance-quizlock-frontend-integration",
    "name": "QuizLock API — 15. Assistance & AI",
    "description": "Module 15 — Assistance (Ticketing étudiant <-> professeur) & AI\n\n1. Requêtes (CRUD)\n2. Messages sur les requêtes\n3. IA",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "requestId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Ticketing (Requests)",
      "item": [
        {
          "name": "GET Requests",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var res = pm.response.json();",
                  "    if (res.data && res.data.length > 0) {",
                  "        pm.collectionVariables.set('requestId', res.data[0]._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/requests?type=TUTORING",
              "host": ["{{baseUrl}}"],
              "path": ["api", "requests"],
              "query": [
                {
                  "key": "status",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "type",
                  "value": "TUTORING"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST Request (Étudiant)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/requests",
              "host": ["{{baseUrl}}"],
              "path": ["api", "requests"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Problème sur l'exercice 4\",\n  \"message\": \"Je bloque sur la question 2, aidez-moi svp.\",\n  \"type\": \"TUTORING\",\n  \"priority\": \"MEDIUM\",\n  \"teacherType\": \"SCHOOL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "GET Request By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/requests/{{requestId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "requests", "{{requestId}}"]
            }
          },
          "response": []
        },
        {
          "name": "PUT Request (Enseignant Update)",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/requests/{{requestId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "requests", "{{requestId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SCHEDULED\",\n  \"scheduledAt\": \"2025-02-15T10:00:00Z\",\n  \"meetingLink\": \"https://meet.google.com/xyz\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "DELETE Request (Annulation)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/requests/{{requestId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "requests", "{{requestId}}"]
            }
          },
          "response": []
        },
        {
          "name": "POST Claim External Request (Teacher)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/requests/{{requestId}}/claim",
              "host": ["{{baseUrl}}"],
              "path": ["api", "requests", "{{requestId}}", "claim"]
            }
          },
          "response": []
        }
      ]
    },
    {
