{
  "info": {
    "_postman_id": "24-settings-reset-password-xkorienta-frontend-integration",
    "name": "Xkorienta API — 24. Paramètres & Reset Password",
    "description": "Module 24 — Paramètres du Compte & Réinitialisation du Mot de Passe\n\nCouvre la page /settings (tous rôles) et /reset-password (public) :\n1. Profil : nom + avatar\n2. Sécurité : mot de passe + changement email\n3. Mes achats : factures PURCHASE_RECEIPT\n4. Mes gains (enseignant) : wallet, Mobile Money, payouts, relevés EARNINGS_STATEMENT\n5. Reset password (page publique, token URL)\n\n**Auth** : Cookie next-auth.session-token (sauf reset-password)\n**Base URL** : {{baseUrl}} (défaut: http://localhost:3001)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string",
      "description": "URL de base de l'API"
    },
    {
      "key": "invoiceNumber",
      "value": "",
      "type": "string",
      "description": "Numéro de facture (ex: INV-2025-0042) — à remplir après liste"
    },
    {
      "key": "resetToken",
      "value": "",
      "type": "string",
      "description": "Token de réinitialisation reçu par email — à remplir manuellement"
    }
  ],
  "item": [
    {
      "name": "1. Profil (Onglet Général)",
      "item": [
        {
          "name": "1.1 Charger le profil",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "profile"]
            },
            "description": "Charge le profil de l'utilisateur connecté. Utilisé pour récupérer l'URL de l'avatar stocké côté serveur."
          }
        },
        {
          "name": "1.2 Mettre à jour le nom",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Martin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "profile"]
            },
            "description": "Met à jour le nom complet. Après succès, appeler update() NextAuth pour rafraîchir la session."
          }
        },
        {
          "name": "1.3 Uploader une photo de profil",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "description": "Image JPG/PNG/WEBP — Max 2MB"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/profile/avatar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "profile", "avatar"]
            },
            "description": "Upload avatar. Formats acceptés: image/jpeg, image/png, image/webp. Taille max: 2MB. Retourne une URL relative à préfixer avec NEXT_PUBLIC_API_URL."
          }
        }
      ]
    },
    {
      "name": "2. Sécurité (Onglet Sécurité)",
      "item": [
        {
          "name": "2.1 Changer le mot de passe",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"ancien_mot_de_passe\",\n  \"newPassword\": \"nouveau_mot_de_passe_fort\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "profile"]
            },
            "description": "Utilise le même endpoint PUT /api/user/profile mais avec currentPassword + newPassword. Validation frontend: les deux champs non vides, nouveau ≠ ancien."
          }
        },
        {
          "name": "2.2 Demander un changement d'email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newEmail\": \"nouvelle.adresse@exemple.com\",\n  \"password\": \"mot_de_passe_actuel\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/email/change",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "email", "change"]
            },
            "description": "Envoie un email de confirmation à la nouvelle adresse. Le lien expire dans 1 heure. L'utilisateur doit se reconnecter après validation."
          }
        }
      ]
    },
    {
      "name": "3. Mes Achats (Onglet Achats — tous rôles)",
      "item": [
        {
          "name": "3.1 Lister les factures d'achat",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/invoices?type=PURCHASE_RECEIPT&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "invoices"],
              "query": [
                { "key": "type", "value": "PURCHASE_RECEIPT" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Retourne les reçus d'achat paginés. Statuts: ISSUED (Émise), SENT (Envoyée), VOIDED (Annulée)."
          }
        },
        {
          "name": "3.2 Voir une facture en HTML",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/invoices/{{invoiceNumber}}/html",
              "host": ["{{baseUrl}}"],
              "path": ["api", "invoices", "{{invoiceNumber}}", "html"]
            },
            "description": "Retourne le HTML de la facture. Ouvrir dans un nouvel onglet via window.open(). Aussi utilisé pour téléchargement PDF (via iframe + print())."
          }
        }
      ]
    },
    {
      "name": "4. Mes Gains (Onglet Gains — Enseignant uniquement)",
      "item": [
        {
          "name": "4.1 Consulter le wallet",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/seller/wallet",
              "host": ["{{baseUrl}}"],
              "path": ["api", "seller", "wallet"]
            },
            "description": "Retourne le solde disponible, total gagné, total versé et la devise (XAF par défaut)."
          }
        },
        {
          "name": "4.2 Lire la configuration Mobile Money",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/seller/payment-info",
              "host": ["{{baseUrl}}"],
              "path": ["api", "seller", "payment-info"]
            },
            "description": "Retourne la config Mobile Money actuelle ou null si non configurée."
          }
        },
        {
          "name": "4.3 Configurer / Modifier le Mobile Money",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileMoneyPhone\": \"+237690000000\",\n  \"mobileMoneyProvider\": \"orange\",\n  \"mobileMoneyName\": \"Alice DUPONT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/seller/payment-info",
              "host": ["{{baseUrl}}"],
              "path": ["api", "seller", "payment-info"]
            },
            "description": "Enregistre les coordonnées Mobile Money. Providers: orange | mtn | other."
          }
        },
        {
          "name": "4.4 Désactiver le virement automatique",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/seller/payment-info",
              "host": ["{{baseUrl}}"],
              "path": ["api", "seller", "payment-info"]
            },
            "description": "Supprime la configuration Mobile Money. Les gains restent dans le wallet (virement manuel requis)."
          }
        },
        {
          "name": "4.5 Demander un virement manuel",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000,\n  \"currency\": \"XAF\",\n  \"recipientPhone\": \"+237690000000\",\n  \"recipientName\": \"Alice DUPONT\",\n  \"recipientProvider\": \"orange\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/seller/payout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "seller", "payout"]
            },
            "description": "Initie un virement Mobile Money. Montant minimum: 500 XAF. Maximum: solde disponible (wallet.balance)."
          }
        },
        {
          "name": "4.6 Historique des virements",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/seller/payout?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["api", "seller", "payout"],
              "query": [
                { "key": "limit", "value": "5" },
                { "key": "page", "value": "1", "disabled": true }
              ]
            },
            "description": "Retourne l'historique des virements. Statuts: PENDING, PROCESSING, COMPLETED, FAILED."
          }
        },
        {
          "name": "4.7 Relevés de ventes (EARNINGS_STATEMENT)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/invoices?type=EARNINGS_STATEMENT&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "invoices"],
              "query": [
                { "key": "type", "value": "EARNINGS_STATEMENT" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Un relevé est généré pour chaque livre vendu. Le montant affiché est positif (gain du vendeur)."
          }
        }
      ]
    },
    {
      "name": "5. Reset Password (Page publique /reset-password)",
      "item": [
        {
          "name": "5.1 Soumettre le nouveau mot de passe",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"nouveau_mot_de_passe_securise\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password"]
            },
            "description": "Endpoint public (pas d'auth requise). Le token vient du paramètre URL ?token=... Mot de passe minimum 6 caractères. Erreur 400 si token expiré/invalide."
          }
        }
      ]
    }
  ]
}
