                  "    pm.expect(json).to.have.property('class');",
                  "    pm.expect(json).to.have.property('exams');",
                  "    pm.expect(json).to.have.property('students');",
                  "    pm.expect(json).to.have.property('teachers');",
                  "    pm.expect(json).to.have.property('syllabuses');",
                  "    pm.expect(json).to.have.property('ranking');",
                  "});",
                  "pm.test('statuts examen valides', () => {",
                  "    const validStatuses = ['upcoming', 'active', 'in_progress', 'completed', 'missed'];",
                  "    pm.response.json().exams.forEach(e => {",
                  "        pm.expect(validStatuses).to.include(e.status);",
                  "    });",
                  "});",
                  "pm.test('classement avec isCurrentUser', () => {",
                  "    const ranking = pm.response.json().ranking;",
                  "    pm.expect(ranking).to.be.an('array');",
                  "    ranking.forEach(r => {",
