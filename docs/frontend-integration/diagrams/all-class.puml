' PACKAGE : DESIGN PATTERNS — lib/patterns/
' ============================================================
package "Design Patterns (lib/)" #FCEBD0 {

    ' --- STRATEGY : Évaluation ---
    package "Strategy: Évaluation" #FFE0B2 {
        interface EvaluationStrategy <<interface>> {
            + evaluate(attempt, question, response): EvaluationResult
        }
        class QCMEvaluationStrategy {
            + evaluate(): EvaluationResult
        }
        class TrueFalseEvaluationStrategy {
            + evaluate(): EvaluationResult
        }
        class AdaptiveEvaluationStrategy {
